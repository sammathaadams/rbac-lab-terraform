# ==============================================================================
# .gitignore  —  Azure RBAC Lab (Lab 2)
# Matches the security pattern from Lab 1 (NTFS File Server Lab)
# ==============================================================================

# ── Sensitive variable files ──────────────────────────────────────────────────
# terraform.tfvars contains real Object IDs — never commit this
terraform.tfvars
*.tfvars
!terraform.tfvars.example       # Keep the example safe to commit

# ── Terraform state files ─────────────────────────────────────────────────────
# State files can contain sensitive resource data and secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform working directory ───────────────────────────────────────────────
.terraform/
.terraform.lock.hcl

# ── Terraform plan output ─────────────────────────────────────────────────────
# Plan files can contain sensitive values from variables
*.tfplan
*.plan

# ── Crash and override files ──────────────────────────────────────────────────
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Lab report output (generated by PowerShell script) ────────────────────────
RBAC_Lab_Report.txt

# ── OS and editor files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.swp
