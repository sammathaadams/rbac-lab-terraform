# ==============================================================================
# terraform.tfvars.example  --  Safe to commit to git
#
# HOW TO USE:
#   cp terraform.tfvars.example terraform.tfvars
#   Fill in your real Object IDs in terraform.tfvars
#   terraform.tfvars is excluded from git via .gitignore
# ==============================================================================

# -- Lab 1 Infrastructure -----------------------------------------------------
# These match the defaults from the NTFS File Server Lab (Lab 1).
# Only change these if your Lab 1 resource group or VM name is different.
resource_group_name = "RG-FileServerLab"
vm_name             = "FS01"
location            = "Central US"

# -- RBAC Object IDs ----------------------------------------------------------
# Replace with the Azure AD Object IDs of your lab users.
# Run scripts/01-get-object-ids.ps1 to retrieve them, or use:
#   az ad user show --id "user@domain.com" --query id -o tsv

sysadmin_object_id      = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
support_user_object_id  = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
auditor_object_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
